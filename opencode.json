{
  "$schema": "https://opencode.ai/config.json",

  "model": "anthropic/claude-sonnet-4-5",

  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],

  "instructions": [
    "docs/Constitution.md",
    ".opencode/instructions/directives.md",
    ".opencode/instructions/team-comms.md",
    ".opencode/instructions/rag-context.md"
  ],

  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    },
    "docfork": {
      "type": "local",
      "command": ["npx", "-y", "docfork"],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "enabled": true
    },
    "figma": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-figma"],
      "environment": {
        "FIGMA_ACCESS_TOKEN": "{env:FIGMA_ACCESS_TOKEN}"
      },
      "enabled": false,
      "comment": "Enable after adding FIGMA_ACCESS_TOKEN to environment"
    }
  },

  "agent": {
    "team-lead": {
      "model": "anthropic/claude-sonnet-4-5"
    },
    "spec-analyst": {
      "model": "anthropic/claude-opus-4-5"
    },
    "spec-architect": {
      "model": "anthropic/claude-opus-4-5"
    },
    "spec-planner": {
      "model": "anthropic/claude-opus-4-5"
    },
    "agile-master": {
      "model": "anthropic/claude-opus-4-5"
    },
    "spec-developer": {
      "model": "anthropic/claude-sonnet-4-5",
      "tools": {
        "mcp_github*": true
      }
    },
    "spec-reviewer": {
      "model": "anthropic/claude-opus-4-5"
    },
    "spec-tester": {
      "model": "anthropic/claude-sonnet-4-5"
    },
    "spec-validator": {
      "model": "anthropic/claude-sonnet-4-5"
    },
    "senior-frontend-architect": {
      "model": "anthropic/claude-opus-4-5"
    },
    "senior-backend-architect": {
      "model": "anthropic/claude-opus-4-5"
    },
    "senior-devops-architect": {
      "model": "anthropic/claude-opus-4-5"
    },
    "security-architect": {
      "model": "anthropic/claude-opus-4-5"
    },
    "open-pencil-designer": {
      "model": "anthropic/claude-sonnet-4-5",
      "tools": {
        "mcp_figma*": true
      }
    },
    "ui-ux-master": {
      "model": "anthropic/claude-sonnet-4-5",
      "tools": {
        "mcp_figma*": true
      }
    },
    "changelog-keeper": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "boilerplate-generator": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "regex-helper": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "readme-generator": {
      "model": "anthropic/claude-haiku-4-5"
    }
  },

  "tools": {
    "mcp_github*": false,
    "mcp_figma*": false
  },

  "compaction": {
    "auto": true,
    "prune": true
  }
}
