{
  "$schema": "https://opencode.ai/config.json",

  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "opencode-dynamic-context-pruning",
    "opencode-shell-strategy",
    "opencode-devcontainers",
    "opencode-type-inject",
    "opencode-vibeguard",
    "opencode-notifier",
    "opencode-skillful",
    "opencode-worktree",
    "oh-my-opencode",
    "opencode-pty"
  ],

  "instructions": [
    "./instructions/rag-context.md",
    "./instructions/team-comms.md",
    "./instructions/directives.md",
    "docs/Constitution.md"
  ],

  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "timeout": 30000,
      "enabled": true
    },
    "memorix": {
      "type": "local",
      "command": ["npx", "-y", "memorix", "serve"],
      "timeout": 30000,
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "timeout": 30000,
      "enabled": true
    },
    "figma-bridge": {
      "type": "local",
      "command": ["npx", "-y", "@gethopp/figma-mcp-bridge"],
      "timeout": 30000,
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["docker", "run", "--rm", "-i", "--init", "--pull=always", "mcr.microsoft.com/playwright/mcp"],
      "timeout": 30000,
      "enabled": true
    }
  },

  "agent": {
    "team-lead": {},
    "spec-analyst": {},
    "spec-architect": {},
    "spec-planner": {},
    "agile-master": {},
    "preflight-checker": {},
    "release-manager": {},
    "spec-developer": {
      "tools": {
        "mcp_github*": true,
        "mcp_gitlab*": true,
        "mcp_playwright*": true,
        "mcp_postgres*": true,
        "mcp_filesystem*": true
      }
    },
    "spec-reviewer": {
      "tools": {
        "mcp_github*": true,
        "mcp_gitlab*": true
      }
    },
    "spec-tester": {
      "tools": {
        "mcp_playwright*": true,
        "mcp_filesystem*": true
      }
    },
    "spec-validator": {
      "tools": {
        "mcp_playwright*": true
      }
    },
    "senior-frontend-architect": {
      "tools": {
        "mcp_playwright*": true,
        "mcp_figma*": true
      }
    },
    "senior-backend-architect": {
      "tools": {
        "mcp_postgres*": true,
        "mcp_docker*": true
      }
    },
    "senior-devops-architect": {
      "tools": {
        "mcp_docker*": true,
        "mcp_gitlab*": true
      }
    },
    "security-architect": {
      "tools": {
        "mcp_filesystem*": true
      }
    },
    "monorepo-architect": {},
    "front-lead": {},
    "react-developer": {},
    "vue-frontend-engineer": {},
    "angular-frontend-engineer": {},
    "svelte-developer": {},
    "nodejs-developer": {},
    "golang-developer": {},
    "php-developer": {},
    "dotnet-developer": {},
    "mobile-developer": {},
    "open-pencil-designer": {
      "tools": {
        "mcp_figma*": true
      }
    },
    "ui-ux-master": {
      "tools": {
        "mcp_figma*": true,
        "mcp_playwright*": true
      }
    },
    "database-architect": {},
    "api-designer": {},
    "api-documenter": {},
    "deployment-engineer": {},
    "devops-troubleshooter": {},
    "compliance-officer": {},
    "realtime-specialist": {},
    "search-specialist": {},
    "payments-specialist": {},
    "data-engineer": {},
    "data-analyst": {},
    "ml-engineer": {},
    "performance-engineer": {},
    "refactor-agent": {},
    "web-researcher": {},
    "technical-writer": {},
    "architecture-keeper": {},
    "product-manager": {},
    "growth-engineer": {},
    "competitor-analyst": {},
    "trend-watcher": {},
    "docs-collector": {},
    "migration-assistant": {},
    "dependency-auditor": {},
    "git-historian": {},
    "sql-optimizer": {},
    "changelog-keeper": {
      "tools": {
        "mcp_github*": true,
        "mcp_gitlab*": true
      }
    },
    "boilerplate-generator": {},
    "regex-helper": {},
    "readme-generator": {},
    "meeting-summarizer": {},
    "email-composer": {},
    "decision-helper": {},
    "learning-planner": {},
    "task-prioritizer": {}
  },

  "tools": {
    "mcp_figma*": true,
    "mcp_playwright*": true,
    "mcp_docker*": true
  },

  "compaction": {
    "auto": true,
    "prune": true
  }
}